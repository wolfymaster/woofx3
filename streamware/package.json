{
  "name": "@woofx3/streamware",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun run --watch src/server.ts",
    "dev:ui": "cd ui && bun run dev",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build:ui": "cd ui && bun run build"
  },
  "dependencies": {
    "obs-websocket-js": "^5.0.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
