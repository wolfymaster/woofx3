{
  "id": "wolfy_profile",
  "name": "Wolfy profile",
  "author": "WolfyMaster LLC",
  "version": "1.0.0",
  "description": "Bundled workflows migrated from woofx3/wooflow/workflows/*.sh. Triggers are provided by the `twitch_platform` module; alerts use the workflow engine's built-in `builtin:action:alert`. Install `twitch_platform` first.",
  "workflows": [
    {
      "id": "follow-workflow",
      "name": "Someone Follows the Stream",
      "trigger": "twitch_platform:trigger:follow.user.twitch",
      "steps": [
        {
          "id": "alert",
          "type": "action",
          "action": "builtin:action:alert",
          "parameters": {
            "widget": "MediaWidget",
            "audioUrl": "https://streamlabs.local.woofx3.tv/pleasure.mp3",
            "mediaUrl": "https://media.tenor.com/LdHGHWDh0Y8AAAPo/look-at-you-i-see-you.mp4",
            "text": "<3  {primary}${trigger.data.userName}{primary} followed <3",
            "duration": 6
          }
        }
      ]
    },
    {
      "id": "subscription-workflow",
      "name": "Someone Subs",
      "trigger": "twitch_platform:trigger:subscribe.user.twitch",
      "steps": [
        {
          "id": "alert",
          "type": "action",
          "action": "builtin:action:alert",
          "parameters": {
            "widget": "MediaWidget",
            "audioUrl": "https://streamlabs.local.woofx3.tv/wolf-hype.mp3",
            "mediaUrl": "https://media.tenor.com/bj2uMQRTdSEAAAPo/dog-husky.mp4",
            "text": "<3  {primary}${trigger.data.userName}{primary} subscribed <3"
          }
        }
      ]
    },
    {
      "id": "bits-workflow",
      "name": "Someone Cheers Bits",
      "trigger": "twitch_platform:trigger:cheer.user.twitch",
      "steps": [
        {
          "id": "confetti",
          "type": "action",
          "action": "builtin:action:alert",
          "parameters": {
            "widget": "MediaWidget",
            "mediaUrl": [
              "https://streamlabs.local.woofx3.tv/bit_overlay.json",
              "https://streamlabs.local.woofx3.tv/confetti2.gif"
            ],
            "audioUrl": "https://streamlabs.local.woofx3.tv/goinsane-pinkpony.mp3",
            "duration": 10,
            "options": [
              {
                "view": {
                  "fullScreen": true,
                  "positionAbsolute": true
                },
                "animation": {
                  "path": [
                    "assets",
                    0,
                    "layers",
                    0,
                    "t",
                    "d",
                    "k",
                    0,
                    "s",
                    "t"
                  ],
                  "value": "${trigger.data.amount} BITS"
                }
              },
              {
                "view": {
                  "fullScreen": true,
                  "positionAbsolute": true
                }
              }
            ]
          }
        }
      ]
    },
    {
      "id": "gifted-subscription-workflow",
      "name": "Someone Gifted Subs",
      "trigger": "twitch_platform:trigger:subscription.gift.twitch",
      "steps": [
        {
          "id": "alert",
          "type": "action",
          "action": "builtin:action:alert",
          "parameters": {
            "widget": "MediaWidget",
            "audioUrl": "https://streamlabs.local.woofx3.tv/allinthistogether.mp3",
            "mediaUrl": "https://media.tenor.com/MojW2yr1vFoAAAPo/money-money-money.mp4",
            "text": "$$ {primary}${trigger.data.gifterName}{primary} gifted {primary}${trigger.data.amount}{primary} {event.data.amount > 1 ? 'subs' : 'sub'} $$"
          }
        }
      ]
    }
  ]
}