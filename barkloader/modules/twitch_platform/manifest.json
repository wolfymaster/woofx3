{
  "id": "twitch_platform",
  "name": "Twitch Platform",
  "version": "1.0.0",
  "description": "Twitch EventSub subscription types as eventbus triggers. IDs are twitch.<EventSub subscription type>. See https://dev.twitch.tv/docs/eventsub/eventsub-subscription-types/",
  "triggers": [
    {
      "id": "twitch.channel.follow",
      "name": "Channel follow",
      "description": "Twitch EventSub: channel.follow",
      "type": "eventbus",
      "category": "platform.twitch"
    },
    {
      "id": "twitch.channel.chat.message",
      "name": "Channel chat message",
      "description": "Twitch EventSub: channel.chat.message",
      "type": "eventbus",
      "category": "platform.twitch"
    },
    {
      "id": "twitch.channel.subscribe",
      "name": "Channel subscribe",
      "description": "Twitch EventSub: channel.subscribe",
      "type": "eventbus",
      "category": "platform.twitch",
      "allowVariants": true,
      "schema": [
        {
          "id": "tier",
          "label": "Subscription tier",
          "type": "select",
          "required": true,
          "options": [
            {
              "value": "1000",
              "label": "Tier 1"
            },
            {
              "value": "2000",
              "label": "Tier 2"
            },
            {
              "value": "3000",
              "label": "Tier 3"
            }
          ],
          "defaultValue": "1000"
        }
      ]
    },
    {
      "id": "twitch.channel.subscription.gift",
      "name": "Channel subscription gift",
      "description": "Twitch EventSub: channel.subscription.gift",
      "type": "eventbus",
      "category": "platform.twitch",
      "allowVariants": true,
      "schema": [
        {
          "id": "tier",
          "label": "Gift tier",
          "type": "select",
          "required": true,
          "options": [
            {
              "value": "1000",
              "label": "Tier 1"
            },
            {
              "value": "2000",
              "label": "Tier 2"
            },
            {
              "value": "3000",
              "label": "Tier 3"
            }
          ],
          "defaultValue": "1000"
        },
        {
          "id": "minQuantity",
          "label": "Minimum gift count",
          "type": "number",
          "required": true,
          "min": 1,
          "defaultValue": 1,
          "placeholder": "e.g. 5"
        }
      ]
    },
    {
      "id": "twitch.channel.cheer",
      "name": "Channel cheer",
      "description": "Twitch EventSub: channel.cheer",
      "type": "eventbus",
      "category": "platform.twitch",
      "schema": [
        {
          "id": "minBits",
          "label": "Minimum bits",
          "type": "number",
          "required": true,
          "min": 1,
          "defaultValue": 100,
          "placeholder": "e.g. 100"
        }
      ],
      "allowVariants": true
    },
    {
      "id": "twitch.channel.raid",
      "name": "Channel raid",
      "description": "Twitch EventSub: channel.raid",
      "type": "eventbus",
      "category": "platform.twitch"
    },
    {
      "id": "twitch.channel.hype_train.begin",
      "name": "Hype train begin",
      "description": "Twitch EventSub: channel.hype_train.begin",
      "type": "eventbus",
      "category": "platform.twitch"
    },
    {
      "id": "twitch.channel.hype_train.progress",
      "name": "Hype train progress",
      "description": "Twitch EventSub: channel.hype_train.progress",
      "type": "eventbus",
      "category": "platform.twitch"
    },
    {
      "id": "twitch.channel.hype_train.end",
      "name": "Hype train end",
      "description": "Twitch EventSub: channel.hype_train.end",
      "type": "eventbus",
      "category": "platform.twitch"
    },
    {
      "id": "twitch.stream.online",
      "name": "Stream online",
      "description": "Twitch EventSub: stream.online",
      "type": "eventbus",
      "category": "platform.twitch"
    },
    {
      "id": "twitch.stream.offline",
      "name": "Stream offline",
      "description": "Twitch EventSub: stream.offline",
      "type": "eventbus",
      "category": "platform.twitch"
    }
  ],
  "functions": [
    {
      "id": "sendChatMessage",
      "name": "Send chat message",
      "runtime": "js",
      "path": "functions/sendChatMessage.js",
      "entryPoint": "sendChatMessage"
    }
  ],
  "actions": [
    {
      "id": "twitch.chat.send",
      "name": "Send chat message",
      "description": "Publish a message to Twitch chat on the broadcaster channel.",
      "call": "sendChatMessage",
      "schema": [
        {
          "id": "message",
          "label": "Message",
          "type": "text",
          "required": true,
          "placeholder": "What should the bot say?"
        }
      ]
    }
  ]
}
